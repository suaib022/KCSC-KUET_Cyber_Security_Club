# ===========================================
# Root .htaccess — Protect non-public directories
# ===========================================
# Blocks direct browser access to app/, config/, storage/, database/, and .env

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to sensitive directories
    RewriteRule ^app/.*$ - [F,L]
    RewriteRule ^config/.*$ - [F,L]
    RewriteRule ^storage/.*$ - [F,L]
    RewriteRule ^database/.*$ - [F,L]

    # Block access to .env files
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^\.env\..*$ - [F,L]
</IfModule>

# Deny access to hidden files (starting with .)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
